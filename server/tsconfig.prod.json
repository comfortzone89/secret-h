{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "../dist",
    "rootDir": ".",
    "noEmit": false,
    "incremental": false,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["server.ts", "lib/**/*.ts", "types/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
